# Variáveis de Ambiente para Rodochagas Logística

# Supabase
# Encontre estas em: Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=seu_url_aqui
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Google Gemini (Opcional - Usado nos Assistentes IA)
VITE_GEMINI_API_KEY=sua_chave_gemini_aqui

# Google Maps (Opcional - Usado em Cotação de Frete e Mapas)
VITE_GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui
